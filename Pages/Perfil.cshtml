@page "/Perfil"
@model INFOGEST_Web.Pages.PerfilModel
@{
    ViewData["Title"] = "Meu Perfil";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8" />
    <title>INFOGEST - @ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="/css/Dashboard.css" />
    <link rel="stylesheet" href="/css/icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        /* --- ESTILOS DO LOGÓTIPO --- */
        .dash-left {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
        }

        .dash-logo {
            color: #3b82f6 !important;
            margin: 0;
            line-height: 1;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-family: sans-serif;
        }

        .dash-subtitle {
            color: #9ca3af !important;
            font-size: 1rem !important;
            font-weight: 400;
            margin-top: 4px;
        } 

        /* --- AVATAR --- */
        .profile-avatar {
            width: 100px;
            height: 100px;
            margin: 0 auto;
            border-radius: 50%;
            background-color: #0d8abc;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 600;
            border: 3px solid #2d3748;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
            text-transform: uppercase;
        }

        /* --- COMPACTO --- */
        h2 {
            font-size: 1.25rem !important;
            font-weight: 600;
        }

        h4 {
            font-size: 1rem !important;
            font-weight: 600;
        }

        .section-title {
            color: #fff;
            font-size: 0.95rem;
            font-weight: 600;
            border-bottom: 1px solid #4b5563;
            padding-bottom: 0.4rem;
            margin-bottom: 0.8rem;
            margin-top: 0.8rem;
        }

        .text-muted-light, .small {
            color: #a0aec0 !important;
            font-size: 0.8rem !important;
        }

        .form-label {
            color: #e2e8f0 !important;
            font-weight: 500;
            font-size: 0.85rem;
            margin-bottom: 0.3rem;
        }

        .form-control, .form-select, .input-group-text, .btn-sm {
            font-size: 0.875rem !important;
            padding: 0.35rem 0.6rem;
        }

            .form-control[readonly], .form-select[disabled] {
                background-color: #2d3748;
                color: #a0aec0;
                border-color: #4a5568;
                cursor: not-allowed;
                opacity: 1;
            }

        #alertBox {
            display: none;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            font-size: 0.9rem;
        }

        .alert-success {
            background-color: #198754;
            color: white;
        }

        .alert-danger {
            background-color: #dc3545;
            color: white;
        }
    </style>
</head>
<body>

    <div class="dash-wrapper">
        <header class="dash-topbar">
            <div class="dash-left">
                <h1 class="dash-logo">INFOGEST</h1>
                <span class="dash-subtitle">Painel de Gestão</span>
            </div>
            <div class="dash-right">
                <a id="btnVoltar" class="btn-top ghost" style="font-size: 0.85rem;">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
        </header>

        <main class="dash-main" style="max-width: 1000px;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="text-white m-0">Perfil do Colaborador</h2>
                    <p class="text-muted-light m-0">Gerencie as suas informações de contacto e consulte os seus dados contratuais.</p>
                </div>
            </div>

            <div id="alertBox"></div>

            <form id="profileForm">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <div class="dash-card text-center h-100 p-3">
                            <div class="mb-2">
                                <div class="profile-avatar" id="avatarLetter">-</div>
                            </div>
                            <h4 class="text-white mb-1" id="labelNome">Carregando...</h4>
                            <p class="text-muted-light mb-3" id="labelCargo">...</p>

                            <div class="d-grid">
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="abrirModalSenha()">
                                    <i class="bi bi-key"></i> Alterar Senha
                                </button>
                            </div>
                            <div class="mt-3 text-muted-light text-start" style="font-size: 0.75rem !important; line-height: 1.2;">
                                <i class="bi bi-info-circle me-1"></i>
                                Para alterar dados como Nome ou NIF, por favor contacte os Recursos Humanos.
                            </div>
                        </div>
                    </div>

                    <div class="col-md-9 mb-3">
                        <div class="dash-card h-100 p-3">
                            <h5 class="section-title"><i class="bi bi-person-lock me-2"></i>Dados Contratuais</h5>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">Nome Completo</label>
                                    <input type="text" id="inputNome" class="form-control" readonly />
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">Cargo</label>
                                    <input type="text" id="inputCargo" class="form-control" readonly />
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">NIF</label>
                                    <input type="text" id="inputNif" class="form-control" readonly />
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">Sexo</label>
                                    <select id="selectSexo" class="form-select" disabled>
                                        <option value="">-- Selecionar --</option>
                                        <option value="M">Masculino</option>
                                        <option value="F">Feminino</option>
                                    </select>
                                </div>
                            </div>

                            <h5 class="section-title mt-3"><i class="bi bi-pencil-square me-2"></i>Dados Editáveis</h5>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">Email</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-secondary text-white border-secondary"><i class="bi bi-at"></i></span>
                                        <input type="email" id="inputEmail" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label">Telemóvel</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-secondary text-white border-secondary"><i class="bi bi-phone"></i></span>
                                        <input type="text" id="inputTelemovel" class="form-control" />
                                    </div>
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Morada</label>
                                <textarea id="inputMorada" class="form-control" rows="2"></textarea>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-3 pt-2 border-top border-secondary">
                                <a href="/HomeAdmin" id="btnCancelar" class="btn btn-outline-light btn-sm">Cancelar</a>
                                <button type="submit" class="btn-top btn-sm">
                                    <i class="bi bi-check-lg me-1"></i> Guardar Alterações
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </main>
    </div>

    <div class="modal fade" id="modalSenha" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #1f2937; color: white; border: 1px solid #374151;">
                <div class="modal-header" style="border-bottom: 1px solid #374151;">
                    <h5 class="modal-title"><i class="bi bi-shield-lock me-2"></i>Alterar Senha</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="formSenha">
                        <div class="mb-3">
                            <label class="form-label">Senha Atual</label>
                            <input type="password" id="senhaAtual" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nova Senha</label>
                            <input type="password" id="senhaNova" class="form-control" required minlength="6">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirmar Nova Senha</label>
                            <input type="password" id="senhaConfirmar" class="form-control" required>
                        </div>
                        <div id="msgErroSenha" class="text-danger small mt-2" style="display:none;"></div>
                    </form>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #374151;">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="submeterNovaSenha()">Confirmar Alteração</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Carrega os dados assim que a página abre
            carregarPerfil();

            // Configura o botão de guardar
            document.getElementById("profileForm").addEventListener("submit", function(event) {
                event.preventDefault(); // Impede o recarregamento da página
                guardarPerfil();
            });
        });

        // --- 1. CARREGAR DADOS (GET) ---
        async function carregarPerfil() {
            try {
                const response = await fetch('/api/Funcionarios/meu-perfil');

                // Se não estiver logado, manda para o Login
                if (response.status === 401) {
                    window.location.href = "/Login";
                    return;
                }

                if (!response.ok) throw new Error("Erro ao carregar dados.");

                const dados = await response.json();

                // ============================================================
                // APLICAR O LINK DE VOLTAR (QUE VEIO DA API)
                // ============================================================
                // A API já decidiu para onde devemos ir (dados.urlVoltar)
                // Nós apenas aplicamos esse link aos botões.

                const linkDestino = dados.urlVoltar; // Fallback se vier vazio

                const btnVoltar = document.getElementById('btnVoltar');
                if (btnVoltar) btnVoltar.href = linkDestino;

                const btnCancelar = document.getElementById('btnCancelar');
                if (btnCancelar) btnCancelar.href = linkDestino;
                // ============================================================

                // Preencher os Inputs (ReadOnly)
                document.getElementById('inputNome').value = dados.nome || "";
                document.getElementById('inputCargo').value = dados.cargo || "";
                document.getElementById('inputNif').value = dados.nif || "";

                // Select do Sexo (Disabled)
                // Se a API devolver "Masculino"/"Feminino", mapeamos para "M"/"F" se necessário,
                // ou assumimos que o value do option é igual ao texto.
                // Aqui assumo que a API devolve o texto exato das options.
                const selectSexo = document.getElementById('selectSexo');
                // Tenta encontrar a opção pelo texto ou valor
                for (let i = 0; i < selectSexo.options.length; i++) {
                    if (selectSexo.options[i].text === dados.sexo || selectSexo.options[i].value === dados.sexo) {
                        selectSexo.selectedIndex = i;
                        break;
                    }
                }

                // Preencher os Inputs Editáveis
                document.getElementById('inputEmail').value = dados.email || "";
                document.getElementById('inputTelemovel').value = dados.telemovel || "";
                document.getElementById('inputMorada').value = dados.morada || "";

                // Preencher a secção do Cartão (Esquerda)
                document.getElementById('labelNome').innerText = dados.nome || "Utilizador";
                document.getElementById('labelCargo').innerText = dados.cargo || "";

                // Gerar Avatar (Primeira Letra)
                if (dados.nome && dados.nome.length > 0) {
                    document.getElementById('avatarLetter').innerText = dados.nome.charAt(0).toUpperCase();
                } else {
                    document.getElementById('avatarLetter').innerText = "U";
                }

            } catch (error) {
                console.error(error);
                mostrarAlerta("Erro ao carregar os dados. Verifique a consola.", "danger");
            }
        }

        // --- 2. GUARDAR DADOS (PUT) ---
        async function guardarPerfil() {
            // Captura a password se o campo existir (pode ser opcional)
            const passwordInput = document.getElementById('inputPassword'); // Se tiveres adicionado o input

            const dadosParaEnviar = {
                email: document.getElementById('inputEmail').value,
                telemovel: document.getElementById('inputTelemovel').value,
                morada: document.getElementById('inputMorada').value,
                // Envia a password apenas se o utilizador escreveu algo
                password: (passwordInput && passwordInput.value.trim() !== "") ? passwordInput.value : null
            };

            const btnGuardar = document.querySelector("#profileForm button[type='submit']");
            const textoOriginal = btnGuardar.innerHTML;
            btnGuardar.disabled = true;
            btnGuardar.innerHTML = "A guardar...";

            try {
                const response = await fetch('/api/Funcionarios/meu-perfil', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dadosParaEnviar)
                });

                if (response.ok) {
                    mostrarAlerta("Dados atualizados com sucesso!", "success");
                    // Limpar campo de password se existir
                    if (passwordInput) passwordInput.value = "";
                } else {
                    const erro = await response.json().catch(() => ({}));
                    mostrarAlerta(erro.message || "Não foi possível guardar as alterações.", "danger");
                }
            } catch (error) {
                console.error(error);
                mostrarAlerta("Erro de conexão ao servidor.", "danger");
            } finally {
                btnGuardar.disabled = false;
                btnGuardar.innerHTML = textoOriginal;
            }
        }

            // --- 3. LÓGICA DO MODAL DE SENHA ---

        // Abre o modal
        function abrirModalSenha() {
            // Limpa os campos antes de abrir
            document.getElementById('senhaAtual').value = '';
            document.getElementById('senhaNova').value = '';
            document.getElementById('senhaConfirmar').value = '';
            document.getElementById('msgErroSenha').style.display = 'none';

            // Usa o Bootstrap para mostrar o modal
            var myModal = new bootstrap.Modal(document.getElementById('modalSenha'));
            myModal.show();
        }

        // Envia a nova senha para o servidor
        async function submeterNovaSenha() {
            const atual = document.getElementById('senhaAtual').value;
            const nova = document.getElementById('senhaNova').value;
            const confirmar = document.getElementById('senhaConfirmar').value;
            const msgErro = document.getElementById('msgErroSenha');

            // Validações locais
            if (!atual || !nova || !confirmar) {
                msgErro.innerText = "Preencha todos os campos.";
                msgErro.style.display = 'block';
                return;
            }

            if (nova !== confirmar) {
                msgErro.innerText = "A nova senha e a confirmação não coincidem.";
                msgErro.style.display = 'block';
                return;
            }

            if (nova.length < 6) {
                msgErro.innerText = "A nova senha deve ter pelo menos 6 caracteres.";
                msgErro.style.display = 'block';
                return;
            }

            // Botão a carregar...
            const btnConfirmar = document.querySelector("#modalSenha .btn-primary");
            const textoOriginal = btnConfirmar.innerText;
            btnConfirmar.disabled = true;
            btnConfirmar.innerText = "A validar...";

            try {
                const response = await fetch('/api/Funcionarios/alterar-senha', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ senhaAtual: atual, senhaNova: nova })
                });

                const resultado = await response.json();

                if (response.ok) {
                    // Sucesso
                    var modalElement = document.getElementById('modalSenha');
                    var modalInstance = bootstrap.Modal.getInstance(modalElement);
                    modalInstance.hide();

                    mostrarAlerta("Senha alterada com sucesso!", "success");
                } else {
                    // Erro (ex: senha atual errada)
                    msgErro.innerText = resultado.message || "Erro ao alterar senha.";
                    msgErro.style.display = 'block';
                }
            } catch (error) {
                console.error(error);
                msgErro.innerText = "Erro de conexão.";
                msgErro.style.display = 'block';
            } finally {
                btnConfirmar.disabled = false;
                btnConfirmar.innerText = textoOriginal;
            }
        }

        // --- HELPER: MOSTRAR ALERTAS ---
        function mostrarAlerta(mensagem, tipo) {
            const alertBox = document.getElementById('alertBox');
            alertBox.innerText = mensagem;

            // Remove classes antigas e adiciona a nova
            alertBox.classList.remove('alert-success', 'alert-danger');
            alertBox.classList.add('alert-' + tipo);

            alertBox.style.display = 'block';

            // Esconder após 3 segundos
            setTimeout(() => {
                alertBox.style.display = 'none';
            }, 3000);
        }
    </script>
</body>
</html>