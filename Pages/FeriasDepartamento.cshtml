@page "/FeriasDepartamento"
@model INFOGEST_Web.Pages.FeriasDepartamentoModel
@{
    ViewData["Title"] = "Gestão de Férias";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>INFOGEST - @ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/icons/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/Dashboard.css">

    <style>
        /* Estilos da Tabela (Dark Mode) */
        .table-container {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 10px;
        }

            .table-container th, .table-container td {
                text-align: left;
                padding: 16px;
                border-bottom: 1px solid #1f2937;
                color: #d1d5db;
                font-size: 14px;
                vertical-align: middle;
            }

            .table-container th {
                color: #9ca3af;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 11px;
                letter-spacing: 0.05em;
                background-color: rgba(31, 41, 55, 0.5);
                border-bottom: 2px solid #374151;
            }

            .table-container tbody tr:hover td {
                background-color: rgba(255, 255, 255, 0.03);
            }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-success {
            background-color: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .badge-danger {
            background-color: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .badge-warning {
            background-color: rgba(245, 158, 11, 0.15);
            color: #fbbf24;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        /* Botões */
        .action-btn {
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid #374151;
            background: rgba(17, 24, 39, 0.5);
            color: #9ca3af;
            cursor: pointer;
            font-size: 13px;
            margin-left: 6px;
            transition: all 0.2s ease;
        }

            .action-btn:hover {
                background: #1f2937;
                color: #f3f4f6;
            }

            .action-btn.approve:hover {
                border-color: #059669;
                color: #34d399;
                background: rgba(5, 150, 105, 0.1);
            }

            .action-btn.reject:hover {
                border-color: #dc2626;
                color: #f87171;
                background: rgba(220, 38, 38, 0.1);
            }

        .btn-disabled {
            opacity: 0.4;
            cursor: not-allowed;
            background: transparent;
            border: 1px dashed #4b5563;
        }

        /* Cards de Estatísticas */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .stat-box {
            background-color: #020617;
            border: 1px solid #1f2937;
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        .stat-label {
            font-size: 12px;
            color: #9ca3af;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .stat-value {
            font-size: 24px;
            font-weight: 700;
            color: #e5e7eb;
        }

        .border-left-warning {
            border-left: 4px solid #f59e0b;
        }

        .border-left-success {
            border-left: 4px solid #10b981;
        }

        .filter-select {
            background-color: #020617;
            color: #e5e7eb;
            border: 1px solid #374151;
            padding: 8px 12px;
            border-radius: 8px;
            outline: none;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="dash-wrapper">

        <header class="dash-topbar">
            <div class="dash-left">
                <h1 class="dash-logo">INFOGEST</h1>
                <span class="dash-subtitle">Gestão de Recursos Humanos / Supervisor</span>
            </div>
            <div class="dash-right">
                <a href="/PainelControlo" class="btn-top ghost">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
        </header>

        <main class="dash-main" style="max-width: 1100px;">

            <div class="stats-row">
                <div class="stat-box border-left-warning">
                    <span class="stat-label">Pendentes</span>
                    <span id="kpiPendentes" class="stat-value text-warning">-</span>
                </div>
                <div class="stat-box border-left-success">
                    <span class="stat-label">Aprovados este Mês</span>
                    <span id="kpiAprovados" class="stat-value text-success">-</span>
                </div>
            </div>

            <section class="dash-intro">
                <div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 15px;">
                    <div>
                        <h2><i class="bi bi-sun me-2 text-warning"></i>Gestão de Férias</h2>
                        <p>Aprove ou recuse os pedidos de férias da equipa.</p>
                    </div>

                    <div style="min-width: 200px;">
                        <label style="font-size: 12px; color: #9ca3af; margin-bottom: 4px; display: block;">Filtrar por estado:</label>
                        <select id="filtroEstado" onchange="carregarFerias()" class="filter-select" style="width: 100%;">
                            <option value="Todos">Todos os Estados</option>
                            <option value="Pendente" selected>Pendentes</option>
                            <option value="Aprovado">Aprovados</option>
                            <option value="Recusado">Rejeitados</option>
                        </select>
                    </div>
                </div>
            </section>

            <section class="company-card" style="margin-top: 20px;">
                <div class="table-responsive" style="overflow-x:auto;">
                    <table class="table-container">
                        <thead>
                            <tr>
                                <th>Colaborador</th>
                                <th>Período</th>
                                <th>Dias Úteis</th>
                                <th>Estado Atual</th>
                                <th style="text-align: right;">Decisão</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-ferias-body">
                        </tbody>
                    </table>
                </div>

                <div style="margin-top: 20px; text-align: right; color: #6b7280; font-size: 12px;">
                    <i class="bi bi-info-circle"></i> A aprovação valida automaticamente os dias no calendário.
                </div>
            </section>

        </main>
    </div>

    <script>
        let todosDadosFerias = [];

        document.addEventListener('DOMContentLoaded', () => {
            carregarFeriasIniciais();
        });

        // 1. GET: Buscar dados da API
        async function carregarFeriasIniciais() {
            const tbody = document.getElementById('tabela-ferias-body');
            tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 40px; color: #9ca3af;"><i class="bi bi-arrow-clockwise spinner" style="font-size: 20px;"></i><br><span style="margin-top:10px; display:block">A carregar pedidos...</span></td></tr>';

            try {
                // Endpoint que vamos criar a seguir
                const response = await fetch('/api/FeriasDepartamento');

                if (!response.ok) {
                    if (response.status === 401) {
                        window.location.href = "/Login";
                        return;
                    }
                    throw new Error("Erro na API");
                }

                todosDadosFerias = await response.json();

                // Atualizar KPIs
                atualizarKPIs();

                // Renderizar Tabela
                carregarFerias();

            } catch (error) {
                console.error(error);
                tbody.innerHTML = `<tr><td colspan="5" style="text-align: center; padding: 20px; color: #f87171;">Erro ao carregar dados.</td></tr>`;
            }
        }

        function atualizarKPIs() {
            const pendentes = todosDadosFerias.filter(f => f.estado === 'Pendente').length;
            const aprovados = todosDadosFerias.filter(f => f.estado === 'Aprovado').length; // Podes refinar para "este mês" se a API mandar datas

            document.getElementById('kpiPendentes').innerText = pendentes + " Pedidos";
            document.getElementById('kpiAprovados').innerText = aprovados + " Pedidos";
        }

        // 2. Renderizar Tabela
        function carregarFerias() {
            const tbody = document.getElementById('tabela-ferias-body');
            const filtro = document.getElementById('filtroEstado').value;

            tbody.innerHTML = '';

            const dadosFiltrados = filtro === 'Todos'
                ? todosDadosFerias
                : todosDadosFerias.filter(f => f.estado === filtro);

            if (dadosFiltrados.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" style="text-align: center; padding: 30px; color: #6b7280;">Nenhum pedido encontrado com estado "${filtro}".</td></tr>`;
                return;
            }

            dadosFiltrados.forEach(f => {
                const tr = document.createElement('tr');
                tr.id = `linha-ferias-${f.id}`;

                // Cores dos badges
                let badgeClass = 'badge-warning';
                let iconClass = 'bi-clock';

                if(f.estado === 'Aprovado') { badgeClass = 'badge-success'; iconClass = 'bi-check-circle'; }
                if(f.estado === 'Recusado' || f.estado === 'Recusado') { badgeClass = 'badge-danger'; iconClass = 'bi-x-circle'; }

                // Botões
                let acoesHtml = '';
                if(f.estado === 'Pendente') {
                    acoesHtml = `
                        <button onclick="decidirFerias(${f.id}, 'Aprovado')" class="action-btn approve" title="Aprovar">
                            <i class="bi bi-check-lg"></i> Aprovar
                        </button>
                        <button onclick="decidirFerias(${f.id}, 'Recusado')" class="action-btn reject" title="Rejeitar">
                            <i class="bi bi-x-lg"></i> Rejeitar
                        </button>
                    `;
                } else {
                    acoesHtml = `<button class="action-btn btn-disabled" disabled>Processado</button>`;
                }

                tr.innerHTML = `
                    <td style="font-weight: 500; color: #f3f4f6;">${f.funcionario}</td>
                    <td>
                        <span style="color:#e5e7eb;">${f.inicio}</span>
                        <span style="color:#6b7280; font-size:12px; margin:0 4px;">até</span>
                        <span style="color:#e5e7eb;">${f.fim}</span>
                    </td>
                    <td style="color: #9ca3af;">${f.dias} dias</td>
                    <td>
                        <span class="badge ${badgeClass}">
                            <i class="bi ${iconClass}" style="margin-right:4px;"></i> ${f.estado}
                        </span>
                    </td>
                    <td style="text-align: right;">${acoesHtml}</td>
                `;

                tbody.appendChild(tr);
            });
        }

        // 3. PUT: Atualizar Estado
        async function decidirFerias(id, novoEstado) {
            const linha = document.getElementById(`linha-ferias-${id}`);
            linha.style.opacity = '0.4';
            linha.style.pointerEvents = 'none';

            try {
                // Endpoint para atualizar estado
                const response = await fetch(`/api/FeriasDepartamento/${id}/estado`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ NovoEstado: novoEstado })
                });

                if (response.ok) {
                    // Atualiza localmente
                    const itemIndex = todosDadosFerias.findIndex(f => f.id === id);
                    if (itemIndex > -1) {
                        todosDadosFerias[itemIndex].estado = novoEstado;
                    }
                    atualizarKPIs();
                    carregarFerias();
                } else {
                    const erro = await response.json();
                    alert("Erro: " + (erro.message || "Falha na operação."));
                    linha.style.opacity = '1';
                    linha.style.pointerEvents = 'auto';
                }

            } catch (error) {
                alert("Erro de comunicação.");
                linha.style.opacity = '1';
                linha.style.pointerEvents = 'auto';
            }
        }
    </script>
</body>
</html>